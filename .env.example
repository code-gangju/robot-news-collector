# ── Supabase ────────────────────────────────────────────────────
# 프로젝트 Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Settings > API > service_role (서버 전용. 절대 프론트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Gemini (요약 기능 선택) ──────────────────────────────────────
# https://aistudio.google.com/app/apikey 에서 발급 (무료)
# 이 값이 없으면 요약 없이 제목+링크만 저장됩니다
GEMINI_API_KEY=AIza...

# ── Naver News API (Google RSS 대신 사용 시) ──────────────────────
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
# 사용하려면 collector.py 내 주석 처리된 줄 교체 필요
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
